{
  "name": "teide",
  "version": "0.0.0",
  "builtin-baseline": "bc8353e09fc8c4ce9936be7446c773df7a0967f4",
  "dependencies": [
    "fmt",
    "function2",
    {
      "name": "glslang",
      "features": [
        "rtti"
      ]
    },
    {
      "name": "sdl3",
      "features": [
        "vulkan"
      ]
    },
    {
      "name": "dbus",
      "default-features": false,
      "platform": "linux"
    },
    {
      "name": "sdl3-image",
      "features": [
        "png",
        "jpeg"
      ]
    },
    "spdlog",
    "taskflow",
    "vulkan",
    "vulkan-headers",
    "vulkan-memory-allocator-hpp",
    "stdexec"
  ],
  "overrides": [
    {
      "name": "taskflow",
      "version": "3.7.0"
    }
  ],
  "features": {
    "benchmarks": {
      "description": "Build benchmarks",
      "dependencies": [
        "benchmark"
      ]
    },
    "examples": {
      "description": "Build examples",
      "dependencies": [
        "assimp"
      ]
    },
    "swiftshader": {
      "description": "Build with Swiftshader support",
      "dependencies": [
        "swiftshader"
      ]
    },
    "tests": {
      "description": "Build tests",
      "dependencies": [
        "gtest",
        "cpptrace",
        {
          "name": "libunwind",
          "platform": "linux"
        }
      ]
    }
  }
}
